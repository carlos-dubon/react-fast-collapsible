{
  "name": "react-fast-collapsible",
  "version": "1.0.1",
  "description": "A tiny, dependency-free React collapsible that animates to auto height with pure CSS (grid 0fr→1fr) — no JavaScript height measurement, no forced reflows.",
  "keywords": [
    "react",
    "collapsible",
    "collapse",
    "accordion",
    "expand",
    "animation",
    "css-grid",
    "height-auto",
    "no-reflow",
    "zero-dependencies"
  ],
  "license": "MIT",
  "author": "Carlos Dubon <holacarlosdubon@gmail.com>",
  "homepage": "https://github.com/carlos-dubon/react-fast-collapsible#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlos-dubon/react-fast-collapsible.git",
    "directory": "packages/react-fast-collapsible"
  },
  "bugs": {
    "url": "https://github.com/carlos-dubon/react-fast-collapsible/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "tsdown && node ../../scripts/copy-readme.mjs"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "react": "19.2.7",
    "tsdown": "0.22.2",
    "typescript": "6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
